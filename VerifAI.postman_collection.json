  "item": [
    {
      "name": "Health",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
              "pm.test(\"Response is healthy\", () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.success).to.be.true;",
              "    pm.expect(json.data.status).to.eql(\"healthy\");",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8000/health",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["health"]
        }
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Student Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Has tokens\", () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "    pm.expect(json.data.access_token).to.not.be.empty;",
                  "    pm.expect(json.data.refresh_token).to.not.be.empty;",
                  "    pm.collectionVariables.set(\"student_access_token\", json.data.access_token);",
                  "    pm.collectionVariables.set(\"student_refresh_token\", json.data.refresh_token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firebase_token\": \"{{firebase_token}}\",\n  \"full_name\": \"Test Student\",\n  \"phone\": \"+1234567890\",\n  \"college_name\": \"MIT\",\n  \"branch\": \"Computer Science\",\n  \"graduation_year\": 2025,\n  \"skills\": \"Python, JavaScript, FastAPI\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/auth/student/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["auth", "student", "register"]
            }
          }
