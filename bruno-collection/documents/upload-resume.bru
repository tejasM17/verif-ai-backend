meta {
  name: Upload Resume
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/documents/upload
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{firebaseToken}}
}

body:multipart-form {
  type: resume
  file: @file(tests/samples/resume.pdf)
}

assert {
  res.status: eq 201
  res.body.success: eq true
  res.body.data.type: eq resume
}
