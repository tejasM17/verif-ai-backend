meta {
  name: Upload Certificate
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/documents/upload
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{firebaseToken}}
}

body:multipart-form {
  type: certificate
  file: @file(tests/samples/cert.png)
}

assert {
  res.status: eq 201
  res.body.success: eq true
  res.body.data.type: eq certificate
}
