meta {
  name: Submit GitHub
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/v1/documents/github
  body: json
  auth: bearer
}

auth:bearer {
  token: {{firebaseToken}}
}

body:json {
  {
    "github_url": "https://github.com/tejasM17"
  }
}

assert {
  res.status: eq 201
  res.body.success: eq true
  res.body.data.type: eq github
}
