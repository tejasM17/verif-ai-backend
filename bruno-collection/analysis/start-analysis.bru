meta {
  name: Start Analysis
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/v1/analysis/start
  body: json
  auth: bearer
}

auth:bearer {
  token: {{firebase_token}}
}

body:json {
  {
    "student_uid": "{{student_uid}}",
    "resume_document_id": "YOUR_RESUME_ID",
    "cert_doc_ids": ["CERT_ID_1"],
    "github_url": "https://github.com/octocat"
  }
}
